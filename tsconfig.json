{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "composite": true,
    "incremental": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.js"
  ],
  "references": [
    { "path": "./backend" },
    { "path": "./infra" },
    { "path": "./tests" }
  ]
}
